// For format details, see https://aka.ms/devcontainer.json. For config options, see the
// README at: https://github.com/devcontainers/templates/tree/main/src/python
{
  "name": "RS Reports Gen",
  // Or use a Dockerfile or Docker Compose file. More info: https://containers.dev/guide/dockerfile
  "image": "mcr.microsoft.com/devcontainers/python:1-3.12-bookworm",
  "features": {
    "ghcr.io/va-h/devcontainers-features/uv:1": {}
  },
  "containerEnv": {
    // Tell The API to use a different port inside codespaces so that it doesn't conflict with the user's root machine use
    "RSAPI_ALTPORT": "TRUE",
    "RME_DATA_BUCKET": "riverscapes-athena",
    "RME_ATHENA_OUTPUT_BUCKET": "riverscapes-athena-output",
    "AWS_DEFAULT_REGION": "us-west-2",
    // mod_spatialite installed via apt (libsqlite3-mod-spatialite)
    "SPATIALITE_PATH": "/usr/lib/x86_64-linux-gnu/mod_spatialite.so",
    "DATA_ROOT": "/workspaces/data"
  },
  // Features to add to the dev container. More info: https://containers.dev/features.
  // "features": {},
  // Use 'forwardPorts' to make a list of ports inside the container available locally.
  "forwardPorts": [
  ],
  // Use 'postCreateCommand' to run commands after the container is created.
  "postCreateCommand": "sh .devcontainer/bootstrap.sh",
  "customizations": {
    "vscode": {
      "extensions": [
        "GitHub.codespaces",
        "GitHub.copilot-chat",
        "mhutchie.git-graph",
        "ms-python.debugpy",
        "ms-python.python",
        "ms-vsliveshare.vsliveshare",
        "njpwerner.autodocstring",
        "redhat.vscode-xml",
        "DavidAnson.vscode-markdownlint",
        "ms-python.debugpy"
      ]
    }
  }
}